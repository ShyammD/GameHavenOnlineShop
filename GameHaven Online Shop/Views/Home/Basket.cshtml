@model List<GameHaven_Online_Shop.Models.BasketItem>

@{
    ViewData["Title"] = "Basket"; <!-- Page title -->
}

<div class="container mt-4">
    <!-- Page Heading -->
    <h1 class="mb-4 fw-bold text-center">Basket</h1>

    <!-- Check if basket is empty -->
    @if (Model.Count == 0)
    {
        <p>Your basket is empty.</p> <!-- Display empty basket message -->

        <div class="d-flex justify-content-start gap-3 mt-4">
            <!-- Continue shopping button -->
            <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">Continue Shopping</a>
        </div>
    }
    else
    {
        <!-- Basket table -->
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Image</th> <!-- Product image -->
                    <th>Product</th> <!-- Product title -->
                    <th class="text-end">Price</th> <!-- Unit price -->
                    <th class="text-end">Quantity</th> <!-- Quantity controls -->
                    <th class="text-end">Total</th> <!-- Line total -->
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <!-- Display product image -->
                            <img src="@Url.Content(item.Image)" width="60" alt="@item.Title" />
                        </td>
                        <td>@item.Title</td> <!-- Product title -->
                        <td class="text-end">£@item.Price</td> <!-- Product price -->

                        <!-- Quantity with - / + buttons -->
                        <td class="text-end">
                            <div class="d-inline-flex align-items-center gap-2">
                                <!-- Decrease quantity button -->
                                <form asp-action="UpdateQuantity" method="post" class="m-0">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="delta" value="-1" />
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-secondary qty-minus"
                                            data-current="@item.Quantity"
                                            data-id="@item.Id"
                                            data-title="@item.Title"
                                            title="Decrease">
                                        &minus;
                                    </button>
                                </form>

                                <!-- Display current quantity -->
                                <span>@item.Quantity</span>

                                <!-- Increase quantity button -->
                                <form asp-action="UpdateQuantity" method="post" class="m-0">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="delta" value="1" />
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-secondary"
                                            title="Increase">
                                        +
                                    </button>
                                </form>
                            </div>
                        </td>

                        <!-- Display total price for this item -->
                        <td class="text-end">£@(item.Price* item.Quantity)</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Basket total -->
        <div class="mt-3 d-flex justify-content-end">
            <h4 class="fw-bold">Total: £@Model.Sum(x => x.Price * x.Quantity)</h4>
        </div>

        <div class="d-flex justify-content-start gap-3 mt-4">
            <!-- Continue shopping button -->
            <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">Continue Shopping</a>

            <!-- Checkout button -->
            <a class="btn btn-outline-primary" asp-controller="Checkout" asp-action="Index">Checkout</a>
        </div>
    }
</div>

<!-- Small confirm modal for removing items -->
<div class="modal fade" id="removeConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center">
                <!-- Modal prompt text -->
                <p class="mb-3" id="removePrompt">Remove this item from your basket?</p>
                <div class="d-flex justify-content-center gap-2">
                    <!-- Confirm remove button -->
                    <button type="button" class="btn btn-primary" id="confirmRemoveBtn">Ok</button>
                    <!-- Cancel remove button -->
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
          let pendingForm = null; // Store form to submit after confirmation
          const modalEl = document.getElementById('removeConfirmModal'); // Modal element
          const removePrompt = document.getElementById('removePrompt'); // Modal prompt element
          const modal = new bootstrap.Modal(modalEl); // Initialise Bootstrap modal 
          const confirmBtn = document.getElementById('confirmRemoveBtn'); // Confirm button 

          // Add click event to all quantity minus buttons
          document.querySelectorAll('.qty-minus').forEach(btn => {
            btn.addEventListener('click', function (e) {
              const current = parseInt(this.getAttribute('data-current') || '0', 10); // Get current quantity
              if (current <= 1) {
                e.preventDefault(); // Prevent default form submit 
                pendingForm = this.closest('form'); // Save form to submit later 
                const title = this.getAttribute('data-title') || 'this item'; // Get item title
                removePrompt.textContent = `Remove ${title} from your basket?`; // Update modal text
                modal.show(); // Show confirmation modal
              }
            });
          });

          // Handle confirm remove button click 
          confirmBtn.addEventListener('click', function () {
            if (pendingForm) {
              pendingForm.submit(); // Submit saved form 
              pendingForm = null; // Clear pending form 
            }
            modal.hide(); // Hide modal
          });
        })();
    </script>
}