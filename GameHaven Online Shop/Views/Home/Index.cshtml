@model IEnumerable<GameHaven.Models.Models.Game>

@{
    ViewData["Title"] = "Home"; <!-- Set page title -->
    ViewData["HideHeaderSearch"] = true; <!-- Hide main header search on home page -->
}

<div class="container mt-4">
    <!-- Search & Sort Section -->
    <form method="get" asp-controller="Home" asp-action="Index" class="row g-2 mb-4">
        <!-- Search Input -->
        <div class="col-md-8">
            <input type="text"
               name="q"
               value="@(ViewData["CurrentSearch"] ?? "")"
               class="form-control"
               placeholder="Search" />
        </div>

        <!-- Sort Dropdown -->
        <div class="col-md-4">
            <select name="sort" class="form-select" onchange="this.form.submit()">
                <option value="">Sort By</option>

                @if (ViewData["CurrentSort"]?.ToString() == "price-asc")
                {
                    <option value="price-asc" selected>Price: Low → High</option> <!-- Sort selected: Price ascending -->
                }
                else
                {
                    <option value="price-asc">Price: Low → High</option>
                }

                @if (ViewData["CurrentSort"]?.ToString() == "price-desc")
                {
                    <option value="price-desc" selected>Price: High → Low</option> <!-- Sort selected: Price descending -->
                }
                else
                {
                    <option value="price-desc">Price: High → Low</option>
                }

                @if (ViewData["CurrentSort"]?.ToString() == "name-asc")
                {
                    <option value="name-asc" selected>Name: A → Z</option> <!-- Sort selected: Name ascending -->
                }
                else
                {
                    <option value="name-asc">Name: A → Z</option>
                }

                @if (ViewData["CurrentSort"]?.ToString() == "name-desc")
                {
                    <option value="name-desc" selected>Name: Z → A</option> <!-- Sort selected: Name descending -->
                }
                else
                {
                    <option value="name-desc">Name: Z → A</option>
                }
            </select>
        </div>
    </form>
</div>

<!-- Promotions Banner Carousel -->
<div id="promoCarousel" class="carousel slide mb-5" data-bs-ride="carousel">
    <div class="carousel-inner rounded shadow-sm">
        <div class="carousel-item active">
            <img src="~/images/homepage/promotions/promo1.png" class="promo-banner" alt="Promotion 1"> <!-- Promo 1 -->
        </div>
        <div class="carousel-item">
            <img src="~/images/homepage/promotions/promo2.png" class="promo-banner" alt="Promotion 2"> <!-- Promo 2 -->
        </div>
        <div class="carousel-item">
            <img src="~/images/homepage/promotions/promo3-1.png" class="promo-banner" alt="Promotion 3"> <!-- Promo 3 -->
        </div>
    </div>

    <!-- Carousel Controls -->
    <button class="carousel-control-prev" type="button" data-bs-target="#promoCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#promoCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<!-- Home Page Best Sellers Section -->
<h2 class="mb-3 fw-bold">Home Page Best Sellers</h2>

<div class="row g-4">
    @foreach (var game in Model)
    {
        <div class="col-md-3">
            <!-- Single Game Card -->
            <div class="card h-100 shadow-sm border-0 hover-shadow">
                <a href="@Url.Action("Details", "Home", new { slug = game.Slug })"> <!-- Link to game details -->
                    <img src="@Url.Content(game.ImageUrl)" class="card-img-top" alt="@game.Title"> <!-- Game image -->
                </a>

                <div class="card-body text-center">
                    <a href="@Url.Action("Details", "Home", new { slug = game.Slug })"
                       class="text-decoration-none text-dark"> <!-- Game title link -->
                        <h5 class="card-title fw-bold">@game.Title</h5> <!-- Game title -->
                    </a>
                    <p class="text-muted mb-2">£@game.Price</p> <!-- Game price -->

                    <!-- Add to Basket Form -->
                    <form asp-action="AddToBasket" method="post">
                        <input type="hidden" name="id" value="@game.Id" /> <!-- Hidden: game ID -->
                        <input type="hidden" name="title" value="@game.Title" /> <!-- Hidden: game title -->
                        <input type="hidden" name="price" value="@game.Price" /> <!-- Hidden: game price -->
                        <input type="hidden" name="image" value="@Url.Content(game.ImageUrl)" /> <!-- Hidden: game image URL -->
                        <button type="submit" class="btn btn-outline-primary btn-sm">Add to Basket</button> <!-- Submit button -->
                    </form>
                </div>
            </div>
        </div>
    }
</div>