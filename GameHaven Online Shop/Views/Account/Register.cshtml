@{
    // Sets the page title shown in the browser and layout
    ViewData["Title"] = "Register";
}

<!-- Page heading for the registration form -->
<h2 class="text-center mb-4">Register</h2>

<!-- Registration form, posts data to AccountController.Register action -->
<form asp-action="Register" method="post" class="mx-auto" style="max-width: 500px;">

    <!-- First Name input field -->
    <div class="form-group mb-3">
        <label for="FirstName">First Name</label>
        <input name="FirstName" class="form-control" required />
    </div>

    <!-- Last Name input field -->
    <div class="form-group mb-3">
        <label for="LastName">Last Name</label>
        <input name="LastName" class="form-control" required />
    </div>

    <!-- Email input field -->
    <div class="form-group mb-3">
        <label for="Email">Email</label>
        <input type="email" name="Email" class="form-control" required />
    </div>

    <!-- Password input field -->
    <div class="form-group mb-3">
        <label for="Password">Password</label>
        <input type="password" id="Password" name="Password" class="form-control" required />
    </div>

    <!-- Password Strength Meter visual progress bar -->
    <div class="mb-2">
        <div class="progress" style="height: 10px;">
            <!-- This inner bar’s width updates dynamically via JavaScript -->
            <div id="passwordStrengthBar" class="progress-bar" style="width: 0%;"></div>
        </div>
    </div>

    <!-- Password rules checklist with visual feedback -->
    <ul class="list-unstyled small mb-3">
        <li id="ruleLength" class="text-danger">❌ At least 8 characters</li>
        <li id="ruleUpper" class="text-danger">❌ At least one uppercase letter</li>
        <li id="ruleLower" class="text-danger">❌ At least one lowercase letter</li>
        <li id="ruleNumber" class="text-danger">❌ At least one number</li>
        <li id="ruleSpecial" class="text-danger">❌ At least one special character</li>
    </ul>

    <!-- Displays any validation messages returned by the model -->
    <div asp-validation-summary="ModelOnly" class="text-danger text-center mb-3"></div>

    <!-- Submit button to create the account -->
    <button type="submit" class="btn btn-success w-100">Register</button>
</form>

<!-- Links external JavaScript file for password strength functionality -->
<script src="~/js/passwordStrength.js" asp-append-version="true"></script>