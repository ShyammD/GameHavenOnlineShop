<div class="modal fade" id="authModal" tabindex="-1" aria-hidden="true">
    <!-- Auth modal container -->
    <div class="modal-dialog modal-dialog-centered">
        <!-- Centered modal dialog -->
        <div class="modal-content rounded-4 shadow">
            <!-- Modal content with rounded corners and shadow -->
            <div class="modal-header">
                <!-- Modal header -->
                <h5 class="modal-title fw-bold">Account</h5> <!-- Modal title -->
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button> <!-- Close button -->
            </div>
            <div class="modal-body">
                <!-- Modal body -->

                <!-- Tabs Navigation -->
                <ul class="nav nav-tabs mb-3">
                    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#login">Login</button></li> <!-- Login tab -->
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#register">Register</button></li> <!-- Register tab -->
                </ul>

                <div class="tab-content">
                    <!-- Tabs content container -->

                    <!-- Login Tab -->
                    <div class="tab-pane fade show active" id="login">
                        <!-- Login tab content -->
                        <form asp-controller="Account" asp-action="Login" method="post">
                            <!-- Login form -->
                            <div class="mb-3"><label>Email</label><input type="email" name="email" class="form-control" required /></div> <!-- Email input -->
                            <div class="mb-3"><label>Password</label><input type="password" name="password" class="form-control" required /></div> <!-- Password input -->
                            <button type="submit" class="btn btn-primary w-100">Login</button> <!-- Login button -->
                        </form>
                    </div>

                    <!-- Register Tab-->
                    <div class="tab-pane fade" id="register">
                        <!-- Register tab content -->
                        <form asp-controller="Account" asp-action="Register" method="post">
                            <!-- Register form -->
                            <div class="mb-3"><label>First Name</label><input type="text" name="FirstName" class="form-control" required /></div> <!-- First name input -->
                            <div class="mb-3"><label>Last Name</label><input type="text" name="LastName" class="form-control" required /></div> <!-- Last name input -->
                            <div class="mb-3"><label>Email</label><input type="email" name="Email" class="form-control" required /></div> <!-- Email input -->
                            <!-- Password Input -->
                            <div class="mb-3">
                                <label>Password</label>
                                <input type="password" id="Password" name="Password" class="form-control" required /> <!-- Password input -->
                            </div>

                            <!-- Password Strength Meter -->
                            <div class="mb-2">
                                <div class="progress" style="height: 10px;">
                                    <!-- Password strength progress bar -->
                                    <div id="passwordStrengthBar" class="progress-bar" style="width: 0%;"></div> <!-- Strength indicator -->
                                </div>
                            </div>

                            <!-- Password Rules -->
                            <ul class="list-unstyled small mb-3">
                                <!-- Password rules list -->
                                <li id="ruleLength" class="text-danger">❌ At least 8 characters</li> <!-- Length rule -->
                                <li id="ruleUpper" class="text-danger">❌ At least one uppercase letter</li> <!-- Uppercase letter rule -->
                                <li id="ruleLower" class="text-danger">❌ At least one lowercase letter</li> <!-- Lowercase letter rule -->
                                <li id="ruleNumber" class="text-danger">❌ At least one number</li> <!-- Number rule -->
                                <li id="ruleSpecial" class="text-danger">❌ At least one special character</li> <!-- Special character rule -->
                            </ul>

                            <div class="mb-3"><label>Home Address</label><input type="text" name="HomeAddress" class="form-control" /></div> <!-- Home address input -->
                            <button type="submit" class="btn btn-success w-100">Register</button> <!-- Register button -->
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- Link JS for Password Strength Meter -->
<script src="~/js/passwordStrength.js" asp-append-version="true"></script> <!-- Password strength JS -->