@model GameHaven_Online_Shop.Models.CheckoutViewModel

@{
    // Sets the page title to "Checkout"
    ViewData["Title"] = "Checkout";
}

<!-- Checkout page header -->
<h2>Checkout</h2>

<!-- Checkout form posts to the Index action -->
<form asp-action="Index" method="post" class="mt-3">

    <!-- Displays any model validation summary errors -->
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <!-- Conditional section: show email input only if user is not logged in -->
    @if (!Model.IsLoggedIn)
    {
        <div class="mb-3">
            <!-- Label and input for guest email -->
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
    }
    else
    {
        <!-- If user is logged in, display their email as read-only -->
        <div class="mb-3">
            <label class="form-label">Email</label>
            <input class="form-control" value="@Model.Email" readonly />
        </div>
    }

    <!-- Card number input field -->
    <div class="mb-3">
        <label asp-for="CardNumber" class="form-label"></label>
        <input asp-for="CardNumber" class="form-control" inputmode="numeric" autocomplete="cc-number" />
        <span asp-validation-for="CardNumber" class="text-danger"></span>
    </div>

    <!-- Expiry date and CVV fields in a row -->
    <div class="row">
        <!-- Expiry date input (MM/YY format) -->
        <div class="col-md-6 mb-3">
            <label asp-for="Expiry" class="form-label"></label>
            <input asp-for="Expiry" class="form-control" placeholder="MM/YY" autocomplete="cc-exp" />
            <span asp-validation-for="Expiry" class="text-danger"></span>
        </div>

        <!-- CVV (security code) input -->
        <div class="col-md-6 mb-3">
            <label asp-for="CVV" class="form-label"></label>
            <input asp-for="CVV" class="form-control" inputmode="numeric" autocomplete="cc-csc" />
            <span asp-validation-for="CVV" class="text-danger"></span>
        </div>
    </div>

    <!-- Submit button for completing payment -->
    <button type="submit" class="btn btn-primary w-100">Pay now</button>
</form>

<!-- Includes client-side validation scripts -->
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}